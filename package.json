{
  "name": "resume-builder",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "build:web": "npm run build --workspace=@resume-builder/shared-types && npm run build --workspace=@resume-builder/web",
    "dev": "turbo dev",
    "dev:web": "npm run dev --workspace=@resume-builder/web",
    "dev:api": "pnpm --filter api dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "db:migrate": "supabase db push",
    "db:seed": "supabase db execute -f supabase/seed.sql"
  },
  "devDependencies": {
    "next": "14.2.5",
    "turbo": "^2.3.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "npm@10"
}
